#. Plugin Name of the plugin
#: nudge.php
msgid "Nudge - Free Shipping Progress Bar for WooCommerce"
msgstr "Nudge - pasek postępu do darmowej dostawy dla WooCommerce"

#. Plugin URI of the plugin
#: nudge.php
msgid "https://plogins.com/nudge/"
msgstr "https://plogins.com/nudge/"

#. Description of the plugin
#: nudge.php
msgid "Show a free-shipping progress bar that nudges shoppers to add more to their cart."
msgstr "Pokaż pasek postępu do darmowej dostawy, który zachęca klientów do dodania większej liczby produktów do koszyka."

#. Author of the plugin
#: nudge.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: nudge.php
msgid "https://plogins.com/"
msgstr "https://plogins.com/"

#: nudge.php:47
msgid "Nudge - Free Shipping Progress Bar for WooCommerce requires WooCommerce to be active."
msgstr "Nudge - pasek postępu do darmowej dostawy dla WooCommerce wymaga aktywnego WooCommerce."

#: src/Admin/Settings.php:37
msgid "Nudge — Free Shipping Bar"
msgstr "Nudge — pasek darmowej dostawy"

#: src/Admin/Settings.php:38
msgid "Nudge"
msgstr "Nudge"

#: src/Admin/Settings.php:74
msgid "A friendly progress bar that shows customers how close they are to free shipping — and how much more to add to unlock it. It updates live as the cart changes."
msgstr "Przyjazny pasek postępu, który pokazuje klientom, jak blisko są darmowej dostawy — i ile jeszcze trzeba dodać, aby ją odblokować. Aktualizuje się na bieżąco wraz ze zmianami w koszyku."

#: src/Admin/Settings.php:80
msgid "General"
msgstr "Ogólne"

#: src/Admin/Settings.php:84
msgid "Enable Nudge"
msgstr "Włącz Nudge"

#: src/Admin/Settings.php:88
msgid "Show the free-shipping progress bar."
msgstr "Pokaż pasek postępu do darmowej dostawy."

#: src/Admin/Settings.php:93
msgid "Cart page"
msgstr "Strona koszyka"

#: src/Admin/Settings.php:93
msgid "Show the bar on the cart."
msgstr "Pokaż pasek w koszyku."

#: src/Admin/Settings.php:94
msgid "Checkout page"
msgstr "Strona zamówienia"

#: src/Admin/Settings.php:94
msgid "Show the bar on checkout."
msgstr "Pokaż pasek podczas składania zamówienia."

#: src/Admin/Settings.php:99
msgid "Free-shipping threshold"
msgstr "Próg darmowej dostawy"

#: src/Admin/Settings.php:104
msgid "Threshold source"
msgstr "Źródło progu"

#: src/Admin/Settings.php:111
msgid "Automatic (from free-shipping method)"
msgstr "Automatyczne (z metody darmowej dostawy)"

#: src/Admin/Settings.php:112
msgid "Manual (fixed amount)"
msgstr "Ręczne (stała kwota)"

#: src/Admin/Settings.php:121
msgid "Automatic reads the minimum order amount from your WooCommerce free-shipping method (the smallest one across your shipping zones). The manual amount is used as a fallback."
msgstr "Tryb automatyczny odczytuje minimalną kwotę zamówienia z metody darmowej dostawy WooCommerce (najniższą spośród wszystkich stref wysyłki). Kwota ręczna jest używana jako wartość awaryjna."

#: src/Admin/Settings.php:126
msgid "Manual amount"
msgstr "Kwota ręczna"

#: src/Admin/Settings.php:130
msgid "In your store currency, before shipping and taxes."
msgstr "W walucie Twojego sklepu, przed kosztami wysyłki i podatkami."

#: src/Admin/Settings.php:136
msgid "Messages"
msgstr "Komunikaty"

#. translators: %s: the {amount} token wrapped in <code>.
#: src/Admin/Settings.php:141
#, php-format
msgid "Use %s in the progress message — it is replaced with the remaining amount, formatted in your store currency."
msgstr "Użyj %s w komunikacie postępu — zostanie zastąpione pozostałą kwotą, sformatowaną w walucie Twojego sklepu."

#: src/Admin/Settings.php:150
msgid "Progress message"
msgstr "Komunikat postępu"

#: src/Admin/Settings.php:158
msgid "Success message"
msgstr "Komunikat sukcesu"

#: templates/progress-bar.php:42
msgid "Progress towards free shipping"
msgstr "Postęp do darmowej dostawy"
