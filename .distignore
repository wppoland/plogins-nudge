# Files excluded from the wp.org build. Nudge is self-contained — it has no
# runtime Composer dependencies, so /vendor (dev tooling only) is NOT shipped.
/.git
/vendor
/.github
/.gitignore
/.distignore
/.wp-env.json
/.wp-env.override.json
/node_modules
/tests
/scripts
/seed-config.php
/seed-ss.php
/docs
/composer.json
/composer.lock
/package.json
/package-lock.json
/phpcs.xml.dist
/phpstan.neon.dist
/phpstan-baseline.neon
/playwright.config.ts
/tsconfig.json
/vite.config.ts
/README.md
/SPEC.md
/.DS_Store

.DS_Store
/.wordpress-org
/test-results
/playwright-report
/.playwright-mcp

# editor backups (never ship / never a badly_named_files reject)
*~
*.bak
